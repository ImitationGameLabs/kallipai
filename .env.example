# LLM Provider (required)

# The LLM backend to use. Supported values: "deepseek", "openai-compatible".
JUST_LLM_PROVIDER=deepseek

# Model identifier passed to the provider (e.g. "deepseek-v4-flash", "glm-5.1").
JUST_LLM_MODEL=

# LLM Credentials

# Required when JUST_LLM_PROVIDER=deepseek.
JUST_LLM_DEEPSEEK_API_KEY=
# Optional: override the default DeepSeek API endpoint.
#JUST_LLM_DEEPSEEK_BASE_URL=

# Required when JUST_LLM_PROVIDER=openai-compatible.
JUST_LLM_OPENAI_COMPAT_API_KEY=
# Optional: override the default OpenAI-compatible API endpoint.
#JUST_LLM_OPENAI_COMPAT_BASE_URL=

# Agent Core (all optional, defaults shown)

# System prompt injected into every LLM session.
# Default: built-in minimal coding agent prompt (see config.rs).
#JUST_AGENT_SYSTEM_PROMPT=

# Maximum tool-call rounds per agent session. Must be > 0.
# Default: 32
#JUST_AGENT_MAX_TOOL_ROUNDS=32

# Root directory for agent workspace. Falls back to current working directory.
# Can also be set via CLI --workspace-root.
#JUST_AGENT_WORKSPACE_ROOT=

# Context window size in tokens. Must be > 0.
# Default: 128000
#JUST_AGENT_CONTEXT_WINDOW_TOKENS=128000

# Tokens reserved for model output within the context window.
# Default: 8192
#JUST_AGENT_OUTPUT_RESERVE_TOKENS=8192

# Strategy for context compaction.
# Default: summarize
#JUST_AGENT_COMPACTION_STRATEGY=summarize

# Maximum tokens for compacted context. Must be > 0.
# Default: 1200
#JUST_AGENT_COMPACT_MAX_TOKENS=1200

# Timeout in seconds for individual tool executions.
# Default: 120
#JUST_AGENT_TOOL_TIMEOUT_SECS=120

# Daemon

# Listen address for the daemon HTTP server.
# Default: 0.0.0.0:3000
#JUST_AGENT_DAEMON_ADDR=0.0.0.0:3000

# Daemon URL used by CLI and TUI clients.
# Set automatically by the daemon at startup; override only if needed.
# Default: http://localhost:3000
#JUST_AGENT_DAEMON_URL=http://localhost:3000

# TUI Client

# Comma-separated list of skill names to activate.
#JUST_AGENT_SKILLS=

# Data & Logging

# Custom data directory (skills, logs). Falls back to platform data dir.
#JUST_AGENT_DATA_DIR=

# Standard tracing filter. Controls log verbosity.
# Default: info
#RUST_LOG=info
