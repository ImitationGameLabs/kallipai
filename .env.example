# LLM Provider (required)

# The LLM backend to use. Supported values: "deepseek", "openai-compatible".
KALLIP_LLM_PROVIDER=deepseek

# Model identifier passed to the provider (e.g. "deepseek-v4-flash", "glm-5.1").
KALLIP_LLM_MODEL=deepseek-v4-flash

# LLM Credentials

# Required when KALLIP_LLM_PROVIDER=deepseek.
KALLIP_LLM_DEEPSEEK_API_KEY=
# Optional: override the default DeepSeek API endpoint.
#KALLIP_LLM_DEEPSEEK_BASE_URL=

# Required when KALLIP_LLM_PROVIDER=openai-compatible.
KALLIP_LLM_OPENAI_COMPAT_API_KEY=
# Optional: override the default OpenAI-compatible API endpoint.
#KALLIP_LLM_OPENAI_COMPAT_BASE_URL=

# Agent Core (all optional, defaults shown)

# System prompt injected into every LLM session.
# Default: built-in minimal coding agent prompt (see config.rs).
#KALLIP_SYSTEM_PROMPT=

# Maximum tool-call rounds per agent session. Must be > 0.
# Default: unlimited (bounded by daemon-wide token budget).
# Set this to enforce a hard round limit independent of token consumption.
#KALLIP_MAX_TOOL_ROUNDS=

# Root directory for agent workspace. Falls back to current working directory.
# Can also be set via CLI --workspace-root.
#KALLIP_WORKSPACE_ROOT=

# Context window size in tokens. Must be > 0.
# Default: 128000
#KALLIP_CONTEXT_WINDOW_TOKENS=128000

# Tokens reserved for model output within the context window.
# Must be less than CONTEXT_WINDOW_TOKENS.
# Default: 8192
#KALLIP_OUTPUT_RESERVE_TOKENS=8192

# Maximum tokens for compacted (summarized) context. Must be > 0 and fit
# within the pinned budget (effective_budget × pinned_budget_ratio).
# Default: 1200
#KALLIP_SUMMARY_MAX_TOKENS=1200

# Timeout in seconds for individual tool executions.
# Default: 120
#KALLIP_TOOL_TIMEOUT_SECS=120

# Fraction of effective budget allocated to pinned context items.
# Must be between 0.0 and 1.0 (exclusive).
# Default: 0.25
#KALLIP_PINNED_BUDGET_RATIO=0.25

# Context usage thresholds (comma-separated percentages, 1-99, sorted ascending, ≥ 2 values).
# The last value triggers auto-compact; preceding values are warnings.
# Default: 50,60,70,80
#KALLIP_CONTEXT_THRESHOLDS=50,60,70,80

# Maximum retries for LLM API calls.
# Default: 3
#KALLIP_MAX_RETRIES=3

# Base delay in seconds for exponential retry backoff. Must be > 0.
# Default: 1
#KALLIP_RETRY_BASE_DELAY_SECS=1

# Daemon-global bash_exec classify preset, read once at startup.
#   default   — catalog commands allow, unclassified ask, denylist/structural deny.
#   auto      — like default, but unclassified commands allow too (denylist still applies).
#   allow-all — debug: every parseable command allows (denylist bypassed).
# Default: default
#KALLIP_POLICY_PRESET=default

# Token budget usage warning thresholds (comma-separated percentages, 1-99,
# sorted ascending, ≥ 1 value). The agent receives a warning message when
# cumulative token consumption crosses each threshold.
# Default: 80,95
#KALLIP_TOKEN_BUDGET_WARNINGS=80,95

# Daemon

# Listen address for the daemon HTTP server.
# Default: 127.0.0.1:3000
#KALLIP_DAEMON_ADDR=127.0.0.1:3000

# URL that agents use to reach this daemon (injected into shell sessions).
# Default: http://127.0.0.1:3000
#KALLIP_ADVERTISE_URL=http://127.0.0.1:3000

# Max queued messages per agent (message channel capacity). When full, send_message returns 503.
# Default: 5
#KALLIP_PROMPT_QUEUE_SIZE=5

# Max concurrent agent instances. Creation returns 503 when at capacity. Restore is exempt.
# Range: 1..=1000
# Default: 50
#KALLIP_MAX_AGENTS=50

# Max direct subagents per agent. Creation returns 503 when the supervisor is at capacity.
# Range: 1..=100
# Default: 20
#KALLIP_MAX_SUBAGENTS=20

# Max HTTP request body size in kilobytes. 0 = axum default (2 MB).
# Oversized requests return 413.
# Default: 1024
#KALLIP_MAX_BODY_SIZE_KB=1024

# Pre-set the daemon operator token. When unset, a random UUID is generated at startup.
# Set this for automation (e.g., CI/CD, Harbor integration) where the token must be known in advance.
# Default: (unset — random UUID printed to stdout)
#KALLIP_OPERATOR_TOKEN=

# User-Agent header sent on outbound LLM chat completion requests.
# Override verbatim (leading/trailing whitespace preserved); illegal header chars fail fast at startup.
# Default: kallip/<daemon-version>
#KALLIP_LLM_API_USER_AGENT=

# Note: KALLIP_AUTH_TOKEN and KALLIP_DAEMON_URL are set at runtime by the
# daemon — do not add them here. See docs/reference/env.md for details.

# Data and Skills

# Custom data directory (agents, logs, skills). Falls back to platform data dir.
#KALLIP_DATA_DIR=

# Direct path to the shared skill directory (used as-is, no suffix appended).
# Checked before DATA_DIR and platform default.
# Default: (unset — uses DATA_DIR/kallip/skills/ or platform default)
#KALLIP_SKILLS_ROOT=

# Logging

# Standard tracing filter. Controls log verbosity.
# Default: info
#RUST_LOG=info

# Agora / Herald (arion dev + prod stack)
# Secrets below — populate .env (gitignored), never commit. See
# docs/reference/container.md for the per-mode contract.

# Stable agora admin token (provisioning authority). If unset, the agora
# generates a fresh sk-admin-... per boot and prints it to `arion logs agora`.
#KALLIP_AGORA_ADMIN_TOKEN=

# Shared secret the lesche (data-plane relay) presents to the agora's
# `/internal/*` ControlPlane API. Must be set to the SAME value on both: the
# agora (KALLIP_AGORA_INTERNAL_TOKEN) and the lesche
# (KALLIP_LESCHE_AGORA_TOKEN). If unset on the agora, it runs standalone with no
# relay connected and no internal surface exposed.
#KALLIP_AGORA_INTERNAL_TOKEN=
#KALLIP_LESCHE_AGORA_TOKEN=

# Daemon operator token. The herald presents the SAME value as KALLIP_AUTH_TOKEN
# (below). If unset, the daemon generates a random one at startup.
#KALLIP_OPERATOR_TOKEN=

# The token the herald uses to authenticate to the daemon. MUST equal
# KALLIP_OPERATOR_TOKEN. (The daemon injects a per-agent KALLIP_AUTH_TOKEN into
# agent shells, overriding whatever .env provides there for the agent.)
#KALLIP_AUTH_TOKEN=

# Herald enrollment: a single-use sk-enroll-... minted via the agora dashboard
# (after a user signs up). Set ONLY on the herald's first boot, then remove it
# (the tagma token is then persisted in the herald-state volume).
#KALLIP_HERALD_ENROLLMENT_CODE=

# --- prod-agora only (dev hardcodes localhost values; do not set these for dev)

# Postgres superuser credentials + db (read by the postgres image). USER and DB
# default to "postgres" when unset, so set them to match the user/db embedded in
# KALLIP_AGORA_DATABASE_URL below -- else the agora cannot connect on first boot.
#POSTGRES_USER=kallip
#POSTGRES_PASSWORD=
#POSTGRES_DB=kallip
# Agora DB url: postgres://<POSTGRES_USER>:<POSTGRES_PASSWORD>@postgres:5432/<POSTGRES_DB>
#KALLIP_AGORA_DATABASE_URL=
# WebAuthn RP: the registrable domain (cannot change without invalidating every
# passkey) and the exact origin the web app is served from.
#KALLIP_AGORA_WEBAUTHN_RP_ID=
#KALLIP_AGORA_WEBAUTHN_RP_ORIGIN=
# Allowed web-app origins; never a wildcard on a public deploy.
#KALLIP_AGORA_CORS_ORIGINS=
# Cookie Secure flag; keep true behind TLS (dev forces false).
#KALLIP_AGORA_COOKIE_SECURE=true
# Session-cookie Domain. Set to the parent domain in a per-subdomain deploy so
# the session cookie is shared across agora.<d> and lesche.<d> (e.g.
# kallipai.com). Unset (commented) = host-only, for a single-origin deploy. Dev
# hardcodes localhost.
#KALLIP_AGORA_SESSION_COOKIE_DOMAIN=
# Trusted reverse-proxy CIDRs for X-Forwarded-For. The default trusts loopback
# only and is CLEARED on a public bind (the agora warns) -- set this to the
# proxy's CIDR so per-client rate limiting works behind a remote TLS proxy.
#KALLIP_AGORA_TRUSTED_PROXIES=

# --- lesche (data-plane relay; separate process from the agora)

# Agora internal root for /internal/* ControlPlane calls (same host, different
# port in dev). MUST equal KALLIP_AGORA_INTERNAL_TOKEN above.
#KALLIP_LESCHE_AGORA_INTERNAL_URL=http://127.0.0.1:7100
#KALLIP_LESCHE_AGORA_TOKEN=
# Listen address (behind a TLS-terminating reverse proxy).
#KALLIP_LESCHE_ADDR=127.0.0.1:7200
# Allowed web-app origins; never a wildcard on a public deploy.
#KALLIP_LESCHE_CORS_ORIGINS=

# --- prod-tagma only

# The public HTTPS URL of the prod-agora subdomain the herald connects to for
# ENROLLMENT ONLY (first run; e.g. https://agora.kallipai.com). The stored tagma
# token is reused thereafter.
#KALLIP_HERALD_AGORA_URL=

# The public HTTPS URL of the prod-lesche subdomain (the data-plane relay) the
# herald holds its tunnel against and posts envelopes / key-exchange responses
# to (e.g. https://lesche.kallipai.com). Per the subdomain topology these are
# two distinct origins sharing the parent domain (kallipai.com), whose session
# cookie is shared via KALLIP_AGORA_SESSION_COOKIE_DOMAIN.
#KALLIP_HERALD_LESCHE_URL=
