#!/usr/bin/env bash

# Load .env first: it may set KALLIP_DEVSHELL, which selects the flake
# devShell below. dotenv watches .env, so changing the value reloads direnv.
dotenv

# `use flake` only watches flake.nix and flake.lock; it cannot see files the
# flake imports (Nix's lazy import graph is opaque to direnv). Watch the whole
# nix/ tree so editing devShell/package/check definitions reloads the shell.
watch_dir nix

# Select the flake devShell:
#   unset / "default" -> everyday toolchain (devShells.default)
#   "tauri"           -> Tauri + Android toolchain (devShells.tauri)
use flake ".#${KALLIP_DEVSHELL:-default}"
