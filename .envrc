#!/usr/bin/env bash

# Load .env first: it may set KALLIP_DEVSHELL, which selects the flake
# devShell below. dotenv watches .env, so changing the value reloads direnv.
dotenv

# `use flake` watches only flake.nix/flake.lock; direnv can't follow Nix's lazy
# imports, so the devShell's nix/ deps must be watched by hand. Its import
# closure:
#   - nix/devshells/  -> default.nix (takes `common`) + tauri.nix
#   - nix/common.nix  -> the `common` arg default.nix consumes
# Editing packages/, checks, docker-images, or prod-composes no longer
# re-triggers the shell. If a devShell ever gains another nix/ import, add it.
watch_dir nix/devshells
watch_file nix/common.nix

# Select the flake devShell:
#   unset / "default" -> everyday toolchain (devShells.default)
#   "tauri"           -> Tauri + Android toolchain (devShells.tauri)
use flake ".#${KALLIP_DEVSHELL:-default}"
