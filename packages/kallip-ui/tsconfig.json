{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    // kallip-common is Deno-first and imports with ".ts" extensions; this flag
    // (paired with noEmit from the base) lets svelte-check follow that source.
    "allowImportingTsExtensions": true
  },
  "include": ["src/**/*.ts", "src/**/*.svelte", "src/**/*.js"],
  // Deno test files use `Deno` globals + jsr: imports that svelte-check (tsc)
  // can't resolve; `deno test` type-checks them with its own types. Excluded
  // here so the library's standalone `check` stays green.
  "exclude": ["src/**/*_test.ts"]
}
